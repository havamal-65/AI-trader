{
  "$schema": "https://schema.freqtrade.io/schema.json",
  "_comment": "Copy this file to config.json and fill in secrets before running. config.json is gitignored.",

  "max_open_trades": 3,
  "stake_currency": "USDT",
  "stake_amount": 25,
  "tradable_balance_ratio": 0.99,
  "dry_run": true,
  "dry_run_wallet": 100,
  "cancel_open_orders_on_exit": false,
  "trading_mode": "spot",
  "unfilledtimeout": {
    "entry": 10,
    "exit": 10,
    "exit_timeout_count": 0,
    "unit": "minutes"
  },
  "entry_pricing": {
    "price_side": "same",
    "use_order_book": false,
    "price_last_balance": 0.0,
    "check_depth_of_market": {
      "enabled": false,
      "bids_to_ask_delta": 1
    }
  },
  "exit_pricing": {
    "price_side": "same",
    "use_order_book": false
  },
  "exchange": {
    "name": "okx",
    "key": "REPLACE_WITH_EXCHANGE_API_KEY",
    "secret": "REPLACE_WITH_EXCHANGE_API_SECRET",
    "ccxt_config": {
      "enableRateLimit": true
    },
    "pair_whitelist": [
      "BTC/USDT",
      "ETH/USDT",
      "SOL/USDT"
    ],
    "pair_blacklist": []
  },
  "pairlists": [
    {
      "method": "StaticPairList"
    }
  ],
  "telegram": {
    "enabled": false,
    "token": "REPLACE_WITH_TELEGRAM_BOT_TOKEN",
    "chat_id": "REPLACE_WITH_TELEGRAM_CHAT_ID"
  },
  "api_server": {
    "enabled": true,
    "listen_ip_address": "0.0.0.0",
    "listen_port": 8080,
    "verbosity": "error",
    "enable_openapi": false,
    "jwt_secret_key": "REPLACE_WITH_RANDOM_SECRET_BEFORE_LIVE",
    "ws_token": "REPLACE_WITH_RANDOM_WS_TOKEN_BEFORE_LIVE",
    "CORS_origins": [],
    "username": "REPLACE_WITH_FREQUI_USERNAME",
    "password": "REPLACE_WITH_FREQUI_PASSWORD"
  },
  "bot_name": "ai-trader",
  "initial_state": "running",
  "force_entry_enable": false,
  "internals": {
    "process_throttle_secs": 5
  }
}
